{
  "name": "@moonit/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "echo \"no tests yet\" && exit 0",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file-if-exists=.env src/seed.ts",
    "db:dbml": "tsx scripts/generate-dbml.ts"
  },
  "dependencies": {
    "@moonit/core": "workspace:*",
    "@moonit/schema": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@moonit/config-ts": "workspace:*",
    "@types/node": "^22.10.0",
    "drizzle-dbml-generator": "^0.10.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.0",
    "typescript": "5.9.2",
    "vitest": "^4.1.9"
  }
}
