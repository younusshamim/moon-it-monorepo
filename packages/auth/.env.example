# Env for the super-admin bootstrap runner only (`pnpm --filter @moonit/auth auth:bootstrap`).
# The runtime `createAuth` factory takes its secret/connection injected — these are validated by
# src/env.ts on direct execution. Copy to packages/auth/.env and fill in.

# Postgres connection (match tooling/docker/docker-compose.yml for local dev).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/moonit

# Must match apps/api's BETTER_AUTH_SECRET (32+ chars) so issued credentials verify there.
BETTER_AUTH_SECRET=replace-with-a-32+-character-random-secret

# Founding super-admin credential (created via Better Auth, hashed into auth_accounts).
SUPER_ADMIN_EMAIL=admin@moonit.local
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin
