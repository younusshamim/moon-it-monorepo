{
  "name": "@moonit/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./session": {
      "moonit-source": "./src/session.ts",
      "types": "./dist/session.d.ts",
      "default": "./dist/session.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "auth:bootstrap": "tsx --conditions=moonit-source --env-file-if-exists=.env src/bootstrap.ts"
  },
  "dependencies": {
    "@moonit/core": "workspace:*",
    "@moonit/db": "workspace:*",
    "@moonit/schema": "workspace:*",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@moonit/config-ts": "workspace:*",
    "@types/node": "catalog:",
    "tsx": "^4.23.0",
    "typescript": "catalog:"
  }
}
