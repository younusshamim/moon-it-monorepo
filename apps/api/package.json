{
  "name": "@moonit/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --conditions=moonit-source --watch --import @swc-node/register/esm-register src/main.ts",
    "build": "swc src --out-dir dist --strip-leading-paths",
    "start": "node --env-file-if-exists=.env dist/main.js",
    "typecheck": "tsc --noEmit",
    "openapi:export": "node --env-file-if-exists=.env --conditions=moonit-source --import @swc-node/register/esm-register src/openapi-export.ts"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.1.0",
    "@moonit/ai": "workspace:*",
    "@moonit/auth": "workspace:*",
    "@moonit/core": "workspace:*",
    "@moonit/db": "workspace:*",
    "@moonit/schema": "workspace:*",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.62.0",
    "@opentelemetry/sdk-node": "^0.205.0",
    "@sentry/node": "^9.42.0",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "fastify": "^5.2.0",
    "ioredis": "^5.6.1",
    "nestjs-pino": "^4.4.0",
    "nestjs-zod": "^5.4.0",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@moonit/config-ts": "workspace:*",
    "@swc-node/register": "^1.10.10",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.5",
    "@types/node": "catalog:",
    "pino-pretty": "^13.1.1",
    "typescript": "catalog:",
    "unplugin-swc": "^1.5.7"
  }
}
