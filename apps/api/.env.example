# Copy to apps/api/.env and fill in. Every key is validated by src/config/env.ts on boot.

# Runtime
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Connections (match tooling/docker/docker-compose.yml for local dev)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/moonit
REDIS_URL=redis://localhost:6379

# Secrets
ANTHROPIC_API_KEY=
BETTER_AUTH_SECRET=replace-with-a-32+-character-random-secret
# Public origin the API is served from (optional; Better Auth derives it from the request if unset).
BETTER_AUTH_URL=http://localhost:3000

# Observability (optional — tracing/Sentry stay inert when unset)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
