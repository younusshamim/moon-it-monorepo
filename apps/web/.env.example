# Copy to apps/web/.env and fill in. Validated by src/lib/env.server.ts / env.client.ts on boot.

# Runtime
NODE_ENV=development

# The NestJS API base URL.
#  - API_URL is used for server-side fetches (RSC, Server Actions, query prefetch). It can be an
#    internal/private hostname in production.
#  - NEXT_PUBLIC_API_URL is inlined into the client bundle for browser-side TanStack Query refetches.
API_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# The web app's own public URL (used for absolute links, redirects). Optional in dev.
NEXT_PUBLIC_APP_URL=http://localhost:3001
